{
  "name": "@dareu/contract",
  "version": "0.1.0",
  "private": true,
  "description": "Compact smart contracts for DareU",
  "type": "module",
  "scripts": {
    "build": "compact compile src/dareu.compact src/managed/dareu",
    "balance:preprod": "tsx scripts/balance.ts preprod",
    "balance:preview": "tsx scripts/balance.ts preview",
    "deploy:preprod": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/deploy.ts preprod",
    "deploy:preview": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/deploy.ts preview",
    "market:create": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts create",
    "market:propose": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts propose",
    "market:dispute": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts dispute",
    "market:finalize": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts finalize",
    "market:vote": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts vote",
    "market:arbiter": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts arbiter",
    "market:cancel": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts cancel",
    "treasury:withdraw": "NODE_OPTIONS=--max-old-space-size=8192 tsx scripts/market.ts withdraw",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:metadata": "tsx scripts/market-metadata.golden.ts",
    "start-proof-server": "docker run -p 6300:6300 midnightntwrk/proof-server:8.0.3 -- midnight-proof-server -v",
    "test": "echo \"Tests not yet implemented\""
  },
  "dependencies": {
    "pg": "^8.13.1",
    "@scure/bip39": "^2.2.0",
    "@midnight-ntwrk/compact-js": "2.5.1",
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/ledger-v8": "8.1.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-types": "4.1.1",
    "@midnight-ntwrk/midnight-js-utils": "4.1.1",
    "@midnight-ntwrk/wallet-sdk-abstractions": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.2",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "4.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "4.0.1",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.2",
    "@midnight-ntwrk/wallet-sdk-shielded": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "3.1.0",
    "rxjs": "^7.8.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
