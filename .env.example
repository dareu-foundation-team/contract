MIDNIGHT_NETWORK=preprod
MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network
MIDNIGHT_NODE_WS_URL=wss://rpc.preprod.midnight.network
MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300
MIDNIGHT_FAUCET_URL=https://midnight-tmnight-preprod.nethermind.dev/
MIDNIGHT_WALLET_START_TIMEOUT_MS=300000
MIDNIGHT_WALLET_SYNC_TIMEOUT_MS=300000
MIDNIGHT_DUST_GENERATION_TIMEOUT_MS=3600000
MIDNIGHT_WALLET_SYNC_ALLOWED_GAP=50
# Cache synced wallet state to contract/.wallet-cache/<network>.json so repeated
# runs resync incrementally instead of replaying the full history. Set to 0 to
# disable; delete the file to force a clean full resync.
MIDNIGHT_WALLET_CACHE=1
# Write a checkpoint every N applied sync events so an interrupted first sync
# resumes from the last checkpoint instead of restarting from zero (default 200000).
MIDNIGHT_WALLET_CHECKPOINT_EVERY=200000
# Wallet key. Provide EITHER a 32-byte hex HD seed in MIDNIGHT_WALLET_SEED, OR a
# BIP39 recovery phrase (助记词, normally 24 English words) in MIDNIGHT_WALLET_MNEMONIC.
# MIDNIGHT_WALLET_MNEMONIC takes precedence. A value containing spaces in
# MIDNIGHT_WALLET_SEED is also treated as a mnemonic.
MIDNIGHT_WALLET_SEED=
MIDNIGHT_WALLET_MNEMONIC=
MIDNIGHT_PRIVATE_STATE_PASSWORD=

DAREU_OWNER_SECRET_KEY=
DAREU_PRIVATE_STATE_ID=dareu-preprod
DAREU_PAYMENT_TOKEN_HEX=
DAREU_LEADER_COMMISSION_BPS=1000
DAREU_PLATFORM_FEE_BPS=200

# --- Admin market CLI (scripts/market.ts) ---
# Postgres connection with INSERT/UPDATE on the markets table (write role).
DATABASE_URL=
# create: market metadata (MARKET_CLOSE_TIME is ISO 8601 or unix ms; MARKET_ORACLE is 32-byte hex)
MARKET_TITLE=
MARKET_CLOSE_TIME=
MARKET_ORACLE=
MARKET_CATEGORY=
MARKET_DESCRIPTION=
MARKET_IMAGE_URL=
MARKET_RESOLUTION_SOURCE=
MARKET_EXTERNAL_ID=
# resolve/cancel: target market id (32-byte hex); resolve also needs MARKET_OUTCOME=YES|NO
MARKET_ID=
MARKET_OUTCOME=
# withdraw: amount in token base units
TREASURY_AMOUNT=
